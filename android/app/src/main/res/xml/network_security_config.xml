<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTPS to Vercel (default) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext HTTP to local network (LAN printers + Bridge) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>

    <!-- Allow cleartext to Vercel (for Capacitor server loading) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">el-waiter.vercel.app</domain>
        <domain includeSubdomains="true">vercel.app</domain>
        <domain includeSubdomains="true">supabase.co</domain>
    </domain-config>
</network-security-config>
